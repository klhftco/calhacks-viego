# Visa API Configuration
VISA_USER_ID=your_visa_user_id_here
VISA_PASSWORD=your_visa_password_here
VISA_API_URL=https://sandbox.api.visa.com

# Visa mTLS Certificates (Base64 encoded)
# To encode: base64 -i cert.pem > cert_base64.txt
VISA_CERT=your_base64_encoded_certificate_here
VISA_KEY=your_base64_encoded_private_key_here
VISA_CA_BUNDLE=your_base64_encoded_ca_bundle_here

# Application URLs
NEXT_PUBLIC_API_URL=http://localhost:3000

# Demo Mode (optional)
DEMO_MODE=true

# Notes:
# 1. Copy this file to .env.local for local development
# 2. Never commit .env.local to version control
# 3. For Vercel deployment, add these to Vercel Dashboard Environment Variables
# 4. Make sure NEXT_PUBLIC_API_URL points to your deployed URL in production
